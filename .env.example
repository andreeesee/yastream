# REQUIRED 
# The Movie Database Read Only Access Token. To get title to search on other providers | eySomething (Not 123asdf123adxf)
TMDB_API_KEY=
# TVDB key. For series with no imdb id | something like asdfb-asdfb-adfb-asdf
TVDB_API_KEY=

# OPTIONAL
# Domain that the addon serve | localhost
DOMAIN=
# Running port | 55913
PORT=
# Debug-key for https://host/dashboard?key=DEBUG_KEY | debug-key
DEBUG_KEY=
# Log level TRACE -> DEBUG -> INFO -> WARN -> ERROR -> NONE | INFO
LOG_LEVEL=
# Cache size in mb | 100
CACHE_SIZE_MB=