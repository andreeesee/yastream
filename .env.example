# REQUIRED 
# The Movie Database Read Only Access Token. To get title to search on other providers | eySomething (Not 123asdf123adxf)
TMDB_API_KEY=
# TVDB key. For series with no imdb id | something like asdfb-asdfb-adfb-asdf
TVDB_API_KEY=

# OPTIONAL
# Display name when show stream result | yastream
DISPLAY_NAME=
# Domain that the addon serve | localhost
DOMAIN=
# Running port | 55913
PORT=
# Debug-key for https://host/dashboard?key=DEBUG_KEY | debug-key
DEBUG_KEY=
# Log level TRACE -> DEBUG -> INFO -> WARN -> ERROR -> NONE | INFO
LOG_LEVEL=
# Cache size in mb | 100
CACHE_SIZE_MB=
# Mediaflow-proxy URL | https://mediaflow-proxy...
MEDIAFLOW_PROXY_URL=
# Mediaflow-proxy password |
MEDIAFLOW_PROXY_PASSWORD=
# Enable sending anonymous tracking (any value to on, leave empty to off) |
ENABLE_ANALYTICS=
# Min title matching score (higher mean only very similar title matches, 0 - 100) | 75
MIN_MATCHING_SCORE=
# Enable warming cache (any value to on, leave empty to off) | true
WARM_CACHE=