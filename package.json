{
  "name": "yastream",
  "version": "0.4.2",
  "description": "Yet Another Stream. Stream asian dramas, series and movies directly with multiple providers. Support catalogs with country selection. Powered by TMDB and TVDB for metadata",
  "scripts": {
    "start": "node --env-file=.env dist/server.js",
    "build": "tsc",
    "dev": "tsc && node --env-file=.env dist/server.js"
  },
  "type": "module",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@stremio-addon/sdk": "^0.3.3",
    "@umami/node": "^0.4.0",
    "axios": "^1.14.0",
    "axios-rate-limit": "^1.8.1",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "fuse.js": "^7.1.0",
    "fuzzball": "^2.2.3",
    "hono": "^4.12.9",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/probe-image-size": "^7.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
